    def save_dataframe(self):
        if self.i == 0:
            self.i = 1
            if self.data is None:
                QMessageBox.warning(self, "Error", "No data to save!")
                self.i = 0
                return
        
            # --- Dialog to select columns ---
            dialog = QDialog(self)
            dialog.setWindowTitle("Select columns to save")
            layout = QVBoxLayout(dialog)
        
            # Create a checkbox for each column
            checkboxes = []
            for col in self.data.columns:
                cb = QCheckBox(col)
                cb.setChecked(False)  # default: all selected
                layout.addWidget(cb)
                checkboxes.append(cb)
        
            # OK / Cancel buttons
            buttons = QDialogButtonBox(QDialogButtonBox.Ok | QDialogButtonBox.Cancel)
            layout.addWidget(buttons)
            buttons.accepted.connect(dialog.accept)
            buttons.rejected.connect(dialog.reject)
        
            if dialog.exec_() == QDialog.Accepted:
                # Collect selected columns
                selected_cols = [cb.text() for cb in checkboxes if cb.isChecked()]
                if not selected_cols:
                    QMessageBox.warning(self, "Error", "No columns selected!")
                    return
        
                # Ask for file path
                options = QFileDialog.Options()
                file_path, _ = QFileDialog.getSaveFileName(self, "Save CSV", "output.csv",
                                                           "CSV Files (*.csv);;All Files (*)",
                                                           options=options)
                if file_path:
                    # Save only selected columns
                    self.data[selected_cols].to_csv(file_path, index=False)
                    QMessageBox.information(self, "Saved", f"Data saved to {file_path}")
                    
            QTimer.singleShot(3000, lambda: setattr(self, 'i', 0))

            
            
    def update_band_combo(self, survey):
        self.band_combo.clear()  # remove previous items
        self.band_combo.addItems(self.survey_bands[survey])
        
    
    # Convert a value in the UI into frequency (cycles/day)
    def to_freq(self, value, unit_label):
        if "Freq" in unit_label:  # already cycles/day
            return value
        if "min" in unit_label:
            return 1440.0 / value
        if "hrs" in unit_label:
            return 24.0 / value
        if "days" in unit_label:
            return 1.0 / value
        return value

    # Convert frequency (cycles/day) → selected UI unit
    def from_freq(self, freq, unit_label):
        if "Freq." in unit_label:  
            return freq
        if "min" in unit_label:
            return 1440.0 / freq
        if "hrs" in unit_label:
            return 24.0 / freq
        if "days" in unit_label:
            return 1.0 / freq
        return freq
    
    def update_min_units(self):
        old_units = self.previous_min_unit
        new_units = self.lsmin_combo.currentText()
    
        try:
            val = float(self.min_edit.text())
        except ValueError:
            return
    
        # Convert old → freq → new
        freq = self.to_freq(val, old_units)
        new_val = self.from_freq(freq, new_units)
    
        self.min_edit.setText(f"{new_val:.6f}".rstrip('0').rstrip('.'))
        self.previous_min_unit = new_units
        
    def update_max_units(self):
        old_units = self.previous_max_unit
        new_units = self.lsmax_combo.currentText()
    
        try:
            val = float(self.max_edit.text())
        except ValueError:
            return
    
        freq = self.to_freq(val, old_units)
        new_val = self.from_freq(freq, new_units)
    
        self.max_edit.setText(f"{new_val:.6f}".rstrip('0').rstrip('.'))
        self.previous_max_unit = new_units

    def parse_ra(self):
        text = self.ra_edit.text()
        s = text.strip()
        if ":" in s or ' ' in s:  # sexagesimal
            return Angle(s, unit=u.hourangle).degree
        return float(s)
    
    def parse_dec(self):
        dectext = self.dec_edit.text()
        s = dectext.strip()
        if ":" in s or " " in s:  # sexagesimal
            return Angle(s, unit=u.deg).degree
        return float(s)
    
    def closeEvent(self, event):
        print("Closing application...")
    
        # Stop timers
        for attr in dir(self):
            obj = getattr(self, attr)
            if isinstance(obj, QTimer):
                obj.stop()
    
        # Close matplotlib windows
        import matplotlib.pyplot as plt
        plt.close('all')
    
        event.accept()




    

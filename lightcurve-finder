    def LS(self):
        self.error_shown = False
        try:
            if self.i == 0:
                self.i = 1
                if self.data is None:
                    QMessageBox.warning(self, "Error", "No data to analyze")
                    self.error_shown = True
                    self.i = 0
                    return
                
                min_val = float(self.min_edit.text())
                max_val = float(self.max_edit.text())
                min_label = self.lsmin_combo.currentText()
                max_label = self.lsmax_combo.currentText()
                freq_start = self.to_freq(min_val, min_label)
                freq_end = self.to_freq(max_val, max_label)
                niters = int(eval(self.niters_edit.text(), {"__builtins__": None}, {}))
                self.lsdata = True
                self.alpha = float(self.alpha_edit.text())
                self.nterms = int(self.nterms_edit.text())
                lsalpha = self.alpha/2
        
                if self.survey in ['ZTF','ASAS-SN']:
                    self.unique_filters = self.filters.unique()
                    for filt in self.unique_filters:
                        mask = self.filters == filt
                        t = self.time[mask]
                        y = self.magnitude[mask]
                        self.yerr = self.mag_err[mask]
                        valid = (~np.isnan(t)) & (~np.isnan(y)) & (~np.isnan(self.yerr))
                        t, y, self.yerr = t[valid], y[valid], self.yerr[valid]
                        if len(t) < 5:
                            continue
                        self.frequency = np.linspace(freq_start, freq_end, niters)
                        ls = LombScargle(t, y, self.yerr, nterms=self.nterms)
                        self.power = ls.power(self.frequency)
                        best_idx = np.argmax(self.power)
                        self.best_freq = self.frequency[best_idx]
                        self.best_period = 1 / self.best_freq
                        phase = (t % self.best_period) / self.best_period
                        self.phase_two_cycles = np.concatenate([phase, phase+1])
                        self.mag_two_cycles = np.concatenate([y, y])
            
                        fig, axs = plt.subplots(1, 2, figsize=(12, 4), gridspec_kw={'width_ratios': [2, 3]})
                        if min_label == 'Min Freq. (c/d)':
                            fig.suptitle(f'Filter: {self.band} | Best Freq: {self.best_freq:.5f} cycles/day')
                            axs[0].plot(self.frequency, self.power, color='black')
                            axs[0].set_xlabel('Frequency (cycles/day)')
                        if min_label == 'Max Per. (min)':
                            fig.suptitle(f'Filter: {self.band} | Best Period: {self.best_period*24*60:.5f} min')
                            axs[0].plot((24*60)/self.frequency, self.power, color='black')
                            axs[0].set_xlabel('Period (minutes)')
                        if min_label == 'Max Per. (hrs)':
                            fig.suptitle(f'Filter: {self.band} | Best Period: {self.best_period*24:.5f} hours')
                            axs[0].plot(24/self.frequency, self.power, color='black')
                            axs[0].set_xlabel('Period (hours)')
                        if min_label == 'Max Per. (days)':
                            fig.suptitle(f'Filter: {self.band} | Best Period: {self.best_period:.5f} days')
                            axs[0].plot(1/self.frequency, self.power, color='black')
                            axs[0].set_xlabel('Period (days)')
                            
                        axs[0].set_ylabel('LS Power')
                        axs[0].set_title('Lomb-Scargle Periodogram')
                        axs[1].errorbar(self.phase_two_cycles, self.mag_two_cycles, yerr=np.concatenate([self.yerr, self.yerr]),
                                        fmt='o', markersize=2, capsize=2, color='black', alpha=lsalpha)
                        axs[1].invert_yaxis()
                        axs[1].set_xlabel("Phase")
                        axs[1].set_ylabel("Magnitude")
                        axs[1].set_title("Phase-folded Light Curve (2 cycles)")
                        axs[1].set_xlim(0, 2)
                        plt.tight_layout()
                        plt.show()
                else:
                    t = self.time
                    if self.survey == 'Gaia':
                        y = self.flux
                        self.yerr = self.flux_err
                    else:
                        y = self.magnitude
                        self.yerr = self.mag_err
                    valid = (~np.isnan(t)) & (~np.isnan(y)) & (~np.isnan(self.yerr))
                    t, y, self.yerr = t[valid], y[valid], self.yerr[valid]
                    self.frequency = np.linspace(freq_start, freq_end, niters)
                    ls = LombScargle(t, y, self.yerr, nterms=self.nterms)
                    self.power = ls.power(self.frequency)
                    best_idx = np.argmax(self.power)
                    self.best_freq = self.frequency[best_idx]
                    self.best_period = 1 / self.best_freq
                    phase = (t % self.best_period) / self.best_period
                    self.phase_two_cycles = np.concatenate([phase, phase+1])
                    self.mag_two_cycles = np.concatenate([y, y])
        
                    fig, axs = plt.subplots(1, 2, figsize=(12, 4), gridspec_kw={'width_ratios': [2, 3]})
                    if min_label == 'Min Freq. (c/d)':
                        fig.suptitle(f'Filter: {self.band} | Best Freq: {self.best_freq:.5f} cycles/day')
                        axs[0].plot(self.frequency, self.power, color='black')
                        axs[0].set_xlabel('Frequency (cycles/day)')
                    if min_label == 'Max Per. (min)':
                        fig.suptitle(f'Filter: {self.band} | Best Period: {self.best_period*24*60:.5f} min')
                        axs[0].plot((24*60)/self.frequency, self.power, color='black')
                        axs[0].set_xlabel('Period (minutes)')
                    if min_label == 'Max Per. (hrs)':
                        fig.suptitle(f'Filter: {self.band} | Best Period: {self.best_period*24:.5f} hours')
                        axs[0].plot(24/self.frequency, self.power, color='black')
                        axs[0].set_xlabel('Period (hours)')
                    if min_label == 'Max Per. (days)':
                        fig.suptitle(f'Filter: {self.band} | Best Period: {self.best_period:.5f} days')
                        axs[0].plot(1/self.frequency, self.power, color='black')
                        axs[0].set_xlabel('Period (days)')
                    axs[0].set_ylabel('LS Power')
                    axs[0].set_title('Lomb-Scargle Periodogram')
                    axs[1].errorbar(self.phase_two_cycles, self.mag_two_cycles, yerr=np.concatenate([self.yerr, self.yerr]),
                                    fmt='o', markersize=2, capsize=2, color='black', alpha=lsalpha)
                    axs[1].set_xlabel("Phase")
                    axs[1].set_ylabel("Flux")
                    axs[1].set_title("Phase-folded Light Curve (2 cycles)")
                    axs[1].set_xlim(0, 2)
                    plt.tight_layout()
                    plt.show()
        except:
            self.i = 0
            self.lsdata = False
            if self.error_shown == False:
                QMessageBox.warning(self, "Error", "Lomb Scargle failed")
            print('Lomb Scargle failed')
        QTimer.singleShot(3000, lambda: setattr(self, 'i', 0))

